# Optional photo-booth-only overrides.
# Copy to .env.photo-booth or .env.photo-booth.local on the Raspberry Pi.

ROLLER_RUMBLE_BOOTH_SERVER_URL=http://127.0.0.1:3187
ROLLER_RUMBLE_BOOTH_ID=booth-dev
ROLLER_RUMBLE_BOOTH_SECRET=dev-secret
ROLLER_RUMBLE_BOOTH_PORT=3197
ROLLER_RUMBLE_BOOTH_DATA_DIR=.roller-rumble-booth
ROLLER_RUMBLE_BOOTH_CAMERA=simulator
ROLLER_RUMBLE_BOOTH_SIMULATOR_PHOTO_PATH=tools/photo-booth-agent/assets/simulated-dslr-photo.jpg
ROLLER_RUMBLE_BOOTH_SCANNER_MODE=simulator
ROLLER_RUMBLE_WLED_DEFAULT_LOOK=solid-white
ROLLER_RUMBLE_UMBRELLA_MODE=simulator

# Local manual testing only. When enabled, type fake:Your Name into the kiosk manual QR input.
ROLLER_RUMBLE_BOOTH_ALLOW_FAKE_QR=1

# Hardware mode:
# ROLLER_RUMBLE_BOOTH_SERVER_URL=http://<admin-laptop-ip>:3187
# ROLLER_RUMBLE_BOOTH_CAMERA=gphoto2
# ROLLER_RUMBLE_GPHOTO_PATH=gphoto2
# ROLLER_RUMBLE_BOOTH_SCANNER_MODE=serial
# ROLLER_RUMBLE_BOOTH_SCANNER_SERIAL_PORT=/dev/serial0
# ROLLER_RUMBLE_BOOTH_SCANNER_BAUD=9600
# ROLLER_RUMBLE_WLED_SERIAL_PORT=/dev/ttyUSB0
# ROLLER_RUMBLE_WLED_BAUD=115200
# ROLLER_RUMBLE_WLED_IDLE_PRESET=1
# ROLLER_RUMBLE_BOOTH_DATA_DIR=/home/pi/roller-rumble-booth
# ROLLER_RUMBLE_UMBRELLA_MODE=process
# ROLLER_RUMBLE_BOOTH_PYTHON=python3
# ROLLER_RUMBLE_UMBRELLA_STEP_PIN=17
# ROLLER_RUMBLE_UMBRELLA_DIR_PIN=27
# ROLLER_RUMBLE_UMBRELLA_ENABLE_PIN=22
# ROLLER_RUMBLE_UMBRELLA_HALL_PIN=23
# ROLLER_RUMBLE_UMBRELLA_PANEL_COUNT=8
# ROLLER_RUMBLE_UMBRELLA_STEPS_PER_REVOLUTION=200
# ROLLER_RUMBLE_UMBRELLA_MICROSTEPS=16
# ROLLER_RUMBLE_UMBRELLA_HOME_DIRECTION=-1
# ROLLER_RUMBLE_UMBRELLA_SPIN_RPM=3
# ROLLER_RUMBLE_UMBRELLA_MOVE_RPM=8
# ROLLER_RUMBLE_UMBRELLA_HOMING_TIMEOUT_MS=15000
